  "types": [
    {
      "name": "ChallengeAccount",
      "docs": [
        "The main challenge account stored on-chain.",
        "Seeds: [b\"challenge\", creator.key(), challenge_id.to_le_bytes()]"
      ],
      "type": {
        "kind": "struct",
        "fields": [
          {
            "name": "creator",
            "docs": [
              "The wallet that created the challenge"
            ],
            "type": "pubkey"
          },
          {
            "name": "challenger",
            "docs": [
              "The wallet that accepted the challenge (zero if not yet accepted)"
            ],
            "type": "pubkey"
          },
          {
            "name": "challenge_id",
            "docs": [
              "Unique numeric ID for this challenge (per creator)"
            ],
            "type": "u64"
          },
          {
            "name": "asset",
            "docs": [
              "Asset symbol, e.g. \"BTC\", \"SOL\", \"ETH\""
            ],
            "type": "string"
          },
          {
            "name": "bet_amount",
            "docs": [
              "Bet amount in lamports (both sides must match)"
            ],
            "type": "u64"
          },
          {
            "name": "target_price_usd_cents",
            "docs": [
              "Target price in USD cents (e.g. $66,500 → 6_650_000)"
            ],
            "type": "u64"
          },
          {
            "name": "direction",
            "docs": [
              "Direction of the creator's prediction"
            ],
            "type": {
              "defined": {
                "name": "PredictionDirection"
              }
            }
          },
          {
            "name": "expires_at",
            "docs": [
              "Unix timestamp when the challenge expires (no more accepts after this)"
            ],
            "type": "i64"
          },
          {
            "name": "resolves_at",
            "docs": [
              "Unix timestamp when the price is evaluated (end of prediction window)"
            ],
            "type": "i64"
          },
          {
            "name": "status",
            "docs": [
              "Current status"
            ],
            "type": {
              "defined": {
                "name": "ChallengeStatus"
              }
            }
          },
          {
            "name": "vault_bump",
            "docs": [
              "PDA bump for the vault"
            ],
            "type": "u8"
          },
          {
            "name": "bump",
            "docs": [
              "PDA bump for this account"
            ],
            "type": "u8"
          }
        ]
      }
    },
    {
      "name": "ChallengeStatus",
      "docs": [
        "On-chain status of a challenge"
      ],
      "type": {
        "kind": "enum",
        "variants": [
          {
            "name": "Open"
          },
          {
            "name": "Active"
          },
          {
            "name": "Settled"
          },
          {
            "name": "Cancelled"
          }
        ]
      }
    },
    {
      "name": "CreateChallengeParams",
      "type": {
        "kind": "struct",
        "fields": [
          {
            "name": "asset",
            "docs": [
              "Asset symbol, e.g. \"BTC\""
            ],
            "type": "string"
          },
          {
            "name": "bet_amount",
            "docs": [
              "Bet amount in lamports"
            ],
            "type": "u64"
          },
          {
            "name": "target_price_usd_cents",
            "docs": [
              "Target price in USD cents (e.g. $66,500 → 6_650_000)"
            ],
            "type": "u64"
          },
          {
            "name": "direction_above",
            "docs": [
              "true = creator predicts price will be ABOVE target; false = BELOW"
            ],
            "type": "bool"
          },
          {
            "name": "expires_at",
            "docs": [
              "Unix timestamp: last moment another user can accept this challenge"
            ],
            "type": "i64"
          },
          {
            "name": "resolves_at",
            "docs": [
              "Unix timestamp: when the price outcome is evaluated"
            ],
            "type": "i64"
          }
        ]
      }
    },
    {
      "name": "CreatorCounter",
      "docs": [
        "A per-creator counter so each creator can have multiple challenges.",
        "Seeds: [b\"creator_counter\", creator.key()]"
      ],
      "type": {
        "kind": "struct",
        "fields": [
          {
            "name": "creator",
            "type": "pubkey"
          },
          {
            "name": "count",
            "type": "u64"
          },
          {
            "name": "bump",
            "type": "u8"
          }
        ]
      }
    },
    {
      "name": "PredictionDirection",
      "docs": [
        "Direction of the price prediction"
      ],
      "type": {
        "kind": "enum",
        "variants": [
          {
            "name": "Above"
          },
          {
            "name": "Below"
          }
        ]
      }
    }
  ]
